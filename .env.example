# Copy to .env and fill in real values. Never commit a real .env.
# Read by waterapi/config.py (pydantic-settings).

# --- Postgres connection ---
PGHOST=localhost
PGPORT=5432
PGDATABASE=water_risk
PGUSER=water_app
PGPASSWORD=change-me

# --- API runtime ---
WATER_API_PORT=8000
WATER_LOG_LEVEL=INFO

# Comma-separated production origins allowed by CORS.
# Any http://localhost:* / http://127.0.0.1:* origin is always allowed for dev.
WATER_CORS_ORIGINS=https://water-risk.scottcampbell.io

# Seed file ingested by `waterapi load` (relative to repo root).
WATER_SEED_PATH=data/processed/app_data.json
